#!/bin/bash
# op-secret: read a secret from 1Password and emit it CLEAN.
#
# Solves the three things that make `op` unreliable for keys and tokens:
#   1. binary resolution: native `op`, else the Windows `op.exe` under WSL
#   2. revealing concealed fields (otherwise you get a reference, not the value)
#   3. stripping Windows carriage returns and the wrapping double-quotes that
#      `--reveal` adds around multiline values (SSH private keys)
#
# Status goes to stderr; the secret (or nothing, when writing a file) is the
# only thing on stdout.
set -e

usage() {
  cat >&2 <<'EOF'
Usage:
  op-secret <op://vault/item/field> [--out FILE] [--cache FILE] [--account A]
  op-secret --item NAME --field FIELD [--vault V] [--account A] [--out FILE] [--cache FILE]

Reads a secret from 1Password and prints it to stdout, or writes it to --out
(mode 600). Strips carriage returns and the wrapping quotes 1Password adds to
revealed multiline values.

Options:
  --item NAME    Item title (use with --field).
  --field FIELD  Field or label to read (e.g. "private key", "password", "credential").
  --vault V      Vault name (optional; disambiguates duplicate item titles).
  --account A    1Password account (optional).
  --out FILE     Write to FILE (mode 600) instead of stdout.
  --cache FILE   Reuse FILE if it is non-empty; otherwise fetch and store it
                 there (mode 600). Use this to avoid repeated unlock prompts.
  -h, --help     Show this help.
EOF
  exit 2
}

# Prefer native op; fall back to the Windows CLI exposed in WSL as op.exe.
resolve_op() {
  if command -v op > /dev/null 2>&1; then
    echo op
  elif command -v op.exe > /dev/null 2>&1; then
    echo op.exe
  else
    echo "op-secret: 1Password CLI not found. Install 'op' (https://developer.1password.com/docs/cli/), or on WSL expose the Windows CLI as op.exe." >&2
    exit 1
  fi
}

REF="" ITEM="" FIELD="" VAULT="" ACCOUNT="" OUT="" CACHE=""

while [ $# -gt 0 ]; do
  case "$1" in
    --item) ITEM="$2"; shift 2 ;;
    --field) FIELD="$2"; shift 2 ;;
    --vault) VAULT="$2"; shift 2 ;;
    --account) ACCOUNT="$2"; shift 2 ;;
    --out) OUT="$2"; shift 2 ;;
    --cache) CACHE="$2"; shift 2 ;;
    -h | --help) usage ;;
    op://*) REF="$1"; shift ;;
    *)
      echo "op-secret: unexpected argument: $1" >&2
      usage
      ;;
  esac
done

# --cache implies a file destination.
if [ -n "$CACHE" ]; then
  OUT="${OUT:-$CACHE}"
  if [ -s "$CACHE" ]; then
    if [ "$OUT" != "$CACHE" ]; then
      cat "$CACHE" > "$OUT"
      chmod 600 "$OUT"
    fi
    echo "op-secret: using cached secret at $CACHE" >&2
    exit 0
  fi
fi

OP="$(resolve_op)"

# Strip CRs, then drop a lone leading and lone trailing double-quote line that
# `--reveal` wraps around multiline values. Harmless for single-line secrets.
clean() {
  tr -d '\r' | sed '1{/^"$/d}' | sed '${/^"$/d}'
}

fetch() {
  if [ -n "$REF" ]; then
    set -- read "$REF"
    [ -n "$ACCOUNT" ] && set -- "$@" --account "$ACCOUNT"
    "$OP" "$@"
  elif [ -n "$ITEM" ] && [ -n "$FIELD" ]; then
    set -- item get "$ITEM" --fields "$FIELD" --reveal
    [ -n "$VAULT" ] && set -- "$@" --vault "$VAULT"
    [ -n "$ACCOUNT" ] && set -- "$@" --account "$ACCOUNT"
    "$OP" "$@"
  else
    usage
  fi
}

if [ -n "$OUT" ]; then
  umask 077
  fetch | clean > "$OUT"
  chmod 600 "$OUT"
  echo "op-secret: wrote secret to $OUT (mode 600)" >&2
else
  fetch | clean
fi
